    "showHumanReadableActionForEveryDiagnostic": true,
    "showAffectedRecordAndFieldWhenAvailable": true,
    "separateValidationFromActivation": true,
    "colorIsSupplementaryOnly": true,
    "rawJsonIsSupplementaryOnly": true
  },
