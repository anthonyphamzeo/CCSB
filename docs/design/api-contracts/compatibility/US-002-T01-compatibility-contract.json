  "blockedTransitions": [
    {
      "id": "CCSB-BLOCK-DOWNGRADE",
      "condition": "target version is lower than persisted product, schema, or projection version",
      "diagnosticCode": "CCSB-COMPAT-DOWNGRADE-BLOCKED"
    },
    {
      "id": "CCSB-BLOCK-PRODUCT-MAJOR",
      "condition": "target product major version differs from persisted product major version",
      "diagnosticCode": "CCSB-COMPAT-PRODUCT-UNSUPPORTED"
    },
    {
      "id": "CCSB-BLOCK-SCHEMA-MAJOR",
      "condition": "configuration schema version is not in supportedConfigurationSchemaVersions",
      "diagnosticCode": "CCSB-COMPAT-SCHEMA-UNSUPPORTED"
    },
    {
      "id": "CCSB-BLOCK-PROJECTION-STALE",
      "condition": "current runtime projection is missing, stale, failed, or on an unsupported schema version",
      "diagnosticCode": "CCSB-COMPAT-PROJECTION-STALE"
    },
    {
      "id": "CCSB-BLOCK-MIGRATION",
      "condition": "migration state is pending, running, failed, blocked, or unknown",
      "diagnosticCode": "CCSB-COMPAT-MIGRATION-REQUIRED"
    },
    {
      "id": "CCSB-BLOCK-SCHEMA-REPORT",
      "condition": "live Dataverse schema compatibility report is missing or has blockers",
      "diagnosticCode": "CCSB-COMPAT-LIVE-SCHEMA-BLOCKED"
    }
  ],
  "migrationStates": [
    {
      "value": "none",
      "terminal": true,
      "activationAllowed": true
