      "activationAllowed": false
    },
    {
      "value": "blocked",
      "terminal": true,
      "activationAllowed": false
    }
  ],
  "activationPolicy": {
    "failClosed": true,
    "consumers": [
      "ccsb_ValidateBoardVersion",
      "ccsb_ActivateBoardVersion",
      "configuration-service-runtime-bootstrap"
    ],
    "blockOnSeverities": [
      "blocking",
      "error"
    ],
    "allowWarnings": true,
    "requiresCurrentProjection": true,
    "requiresZeroPendingMigrations": true,
    "requiresCompatibilityReportZeroBlockers": true,
    "writesValidationResults": true
  },
  "diagnosticCodes": [
    {
      "code": "CCSB-COMPAT-PRODUCT-UNSUPPORTED",
      "severity": "blocking",
      "category": "ProductVersion",
      "message": "The board version targets an unsupported CCSB product version.",
      "recommendedAction": "Upgrade through a supported compatibility path or clone the board version for migration."
    },
    {
      "code": "CCSB-COMPAT-SCHEMA-UNSUPPORTED",
      "severity": "blocking",
      "category": "ConfigurationSchema",
      "message": "The board version uses an unsupported configuration schema version.",
      "recommendedAction": "Run the schema migration/backfill package, then revalidate the board version."
    },
    {
      "code": "CCSB-COMPAT-PROJECTION-STALE",
      "severity": "blocking",
      "category": "RuntimeProjection",
      "message": "The runtime projection is missing, stale, failed, or on an unsupported projection schema version.",
      "recommendedAction": "Regenerate the projection after configuration validation passes."
    },
    {
      "code": "CCSB-COMPAT-MIGRATION-REQUIRED",
      "severity": "blocking",
      "category": "MigrationState",
      "message": "A required compatibility migration has not completed successfully.",
      "recommendedAction": "Complete or repair the migration before activation."
    },
    {
      "code": "CCSB-COMPAT-DOWNGRADE-BLOCKED",
      "severity": "blocking",
      "category": "UpgradePath",
      "message": "Downgrade activation is not supported for this board version.",
      "recommendedAction": "Restore the prior active board pointer or deploy an additive forward repair."
    },
    {
      "code": "CCSB-COMPAT-LIVE-SCHEMA-BLOCKED",
      "severity": "blocking",
      "category": "LiveSchema",
      "message": "Live Dataverse schema compatibility validation is missing or has blocking diagnostics.",
      "recommendedAction": "Run the foundation schema compatibility gate and resolve blockers."
    },
    {
      "code": "CCSB-COMPAT-FEATURE-FLAG-DISABLED",
      "severity": "blocking",
      "category": "FeatureFlag",
      "message": "A required compatibility feature flag is disabled.",
      "recommendedAction": "Enable the feature flag only after release gates pass."
    }
